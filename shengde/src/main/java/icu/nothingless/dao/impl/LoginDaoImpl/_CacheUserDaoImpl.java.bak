package icu.nothingless.dao.impl.LoginDaoImpl;

import java.util.Map;
import java.util.Random;
import java.util.concurrent.atomic.AtomicInteger;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

import com.fasterxml.jackson.databind.DeserializationFeature;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.SerializationFeature;
import icu.nothingless.dao.interfaces.iUserDao;
import icu.nothingless.pojo.adapter.iUserSTOAdapter;
import icu.nothingless.tools.RedisUtil;
import icu.nothingless.tools.ServiceFactory;

/**
 * 用户数据缓存层实现
 * 
 * 优化点：
 * 防缓存雪崩：随机 TTL + 异步续期
 * 防缓存击穿：互斥锁（基于 Redis SETNX）
 * 防缓存穿透：空值缓存 + 布隆过滤器（简易版：本地 HashSet）
 * 熔断降级：失败计数器，连续失败直接走 DB
 * 双写一致：延迟双删 + 异步补偿
 * 异常规范化：业务结果对象替代异常控制流
 */
public class _CacheUserDaoImpl implements iUserDao {
    
    // ==================== 依赖注入 ====================
    
    private final iUserDao userDao;
    private static final Logger logger = LoggerFactory.getLogger(CacheUserDaoImpl.class);
    
    // JSON 序列化器（线程安全，预配置）
    private static final ObjectMapper OBJECT_MAPPER = new ObjectMapper()
        .disable(DeserializationFeature.FAIL_ON_UNKNOWN_PROPERTIES)
        .disable(SerializationFeature.FAIL_ON_EMPTY_BEANS);
    
    // ==================== 缓存配置 ====================
    
    private static final int BASE_CACHE_TTL_SECONDS = 1800;      // 基础 30 分钟
    private static final int TTL_RANDOM_RANGE_SECONDS = 300;      // 随机偏移 5 分钟
    private static final int EMPTY_CACHE_TTL_SECONDS = 60;        // 空值缓存 60 秒
    private static final int LOCK_TTL_SECONDS = 10;               // 互斥锁 10 秒
    private static final int HALF_TTL_REFRESH_THRESHOLD = 900;      // 半过期时续期（15分钟）
    
    private static final String KEY_PREFIX_USERNAME = "user:username:";
    private static final String KEY_PREFIX_ID = "user:id:";
    private static final String KEY_PREFIX_LOCK = "user:lock:";
    private static final String EMPTY_PLACEHOLDER = "__EMPTY__";
    
    // ==================== 熔断配置 ====================
    
    private static final int CIRCUIT_BREAKER_THRESHOLD = 5;       // 连续失败 5 次熔断
    private static final long CIRCUIT_BREAKER_TIMEOUT_MS = 30000; // 熔断 30 秒
    private final AtomicInteger redisFailureCount = new AtomicInteger(0);
    private volatile long circuitBreakerOpenTime = 0;
    private volatile boolean circuitBreakerOpen = false;
    
    // ==================== 构造器 ====================
    
    public _CacheUserDaoImpl() {
        this.userDao = ServiceFactory.createInstance(iUserDao.class);
    }
    
    // 测试/特殊场景用的构造器
    public _CacheUserDaoImpl(iUserDao userDao) {
        this.userDao = userDao;
    }
    
    // ==================== 核心业务方法 ====================

    /**
     * 根据用户名查询用户（防击穿 + 防雪崩 + 熔断降级）
     * @throws Exception 
     */
    @Override
    public UserQueryResult findByUsername(String username) throws Exception {
        // 参数校验
        if (isBlank(username)) {
            return UserQueryResult.paramError("用户名不能为空");
        }
        
        final String normalizedUsername = username.trim();
        final String cacheKey = buildUsernameKey(normalizedUsername);
        
        // 熔断检查：Redis 连续失败时直接走 DB
        if (isCircuitBreakerOpen()) {
            logger.warn("Redis 熔断器开启，直接查询数据库，username={}", normalizedUsername);
            return queryDB(normalizedUsername, false);
        }
        
        // 尝试读缓存
        String cachedJson = safeRedisGet(cacheKey);
        
        if (cachedJson != null) {
            // 命中缓存
            if (EMPTY_PLACEHOLDER.equals(cachedJson)) {
                logger.debug("缓存命中空值，用户不存在，username={}", normalizedUsername);
                return UserQueryResult.notFound();
            }
            
            // 正常命中，异步检查是否需要续期
            iUserSTOAdapter user = safeDeserialize(cachedJson);
            if (user != null) {
                asyncRefreshIfNeeded(cacheKey, cachedJson);
                return UserQueryResult.success(user);
            }
            
            // 反序列化失败，视为缓存失效
            logger.warn("缓存数据损坏，key={}", cacheKey);
        }
        
        // 缓存未命中：加互斥锁防击穿
        String lockKey = buildLockKey(normalizedUsername);
        boolean lockAcquired = tryLock(lockKey);
        
        if (!lockAcquired) {
            // 获取锁失败：短暂等待后重试读缓存（其他线程可能已写入）
            sleepQuietly(100);
            cachedJson = safeRedisGet(cacheKey);
            
            if (cachedJson != null && !EMPTY_PLACEHOLDER.equals(cachedJson)) {
                iUserSTOAdapter user = safeDeserialize(cachedJson);
                if (user != null) {
                    return UserQueryResult.success(user);
                }
            }
            
            // 重试后仍无缓存，直接查 DB（降级）
            logger.warn("获取分布式锁失败，直接查询数据库，username={}", normalizedUsername);
            return queryDB(normalizedUsername, true);
        }
        
        try {
            // 双检锁：获取锁后再查一次缓存
            cachedJson = safeRedisGet(cacheKey);
            if (cachedJson != null) {
                if (EMPTY_PLACEHOLDER.equals(cachedJson)) {
                    return UserQueryResult.notFound();
                }
                iUserSTOAdapter user = safeDeserialize(cachedJson);
                if (user != null) {
                    return UserQueryResult.success(user);
                }
            }
            
            // 查数据库
            iUserSTOAdapter user = userDao.findByUsername(normalizedUsername);
            
            // 写入缓存（双 Key）
            if (user != null) {
                safeCacheUserDoubleKey(user);
                return UserQueryResult.success(user);
            } else {
                // 缓存空值防穿透
                safeCacheEmpty(cacheKey);
                return UserQueryResult.notFound();
            }
            
        } finally {
            releaseLock(lockKey);
        }
    }
    
    /**
     * 登录操作（延迟双删保证一致性）
     */
    public Boolean doLogin(iUserSTOAdapter login) throws Exception{
        if (login == null || isBlank(login.getUserId())) {
            return false;
        }
        
        // 先删缓存（第一次删除）
        evictUserCacheQuietly(login.getUserId(), null);
        
        // 更新数据库
        Boolean result = false;
        try {
            result = userDao.doLogin(login);
        } catch (Exception e) {
            logger.error("数据库登录操作异常", e);
            return false;
        }
        
        // 成功后再删缓存（第二次删除，延迟执行）
        if (Boolean.TRUE.equals(result)) {
            // 延迟 500ms 执行第二次删除，覆盖并发读造成的脏缓存
            delayedEvict(login.getUserId(), null, 500);
        }
        
        return result;
    }
    
    /**
     * 注册操作（清相关缓存）
     */
    @Override
    public Boolean doRegister(Map<String, String> register) throws Exception {
        if (register == null || register.isEmpty()) {
            return false;
        }
        
        Boolean result = userDao.doRegister(register);
        
        // 注册成功，如果缓存中有"用户不存在"的空值，需要清除
        String username = register.get("username");
        if (Boolean.TRUE.equals(result) && !isBlank(username)) {
            String cacheKey = buildUsernameKey(username.trim());
            safeRedisDel(cacheKey);
        }
        
        return result;
    }
    
    /**
     * 修改密码（延迟双删）
     */
    @Override
    public Boolean updatePwd(String username, String newPassword)throws Exception {
        if (isBlank(username) || isBlank(newPassword)) {
            return false;
        }
        
        final String normalizedUsername = username.trim();
        
        // 先获取 userId（用于删缓存）
        String userId = getUserIdByUsernameQuietly(normalizedUsername);
        
        // 第一次删缓存
        evictUserCacheQuietly(userId, normalizedUsername);
        
        // 更新数据库
        Boolean result = userDao.updatePwd(normalizedUsername, newPassword);
        
        // 延迟双删
        if (Boolean.TRUE.equals(result)) {
            delayedEvict(userId, normalizedUsername, 500);
        }
        
        return result;
    }
    
    // ==================== 缓存工具方法 ====================
    
    /**
     * 双 Key 缓存用户数据（带随机 TTL 防雪崩）
     */
    private void safeCacheUserDoubleKey(iUserSTOAdapter user) {
        if (user == null) {
            return;
        }
        
        String username = user.getUserAccount();
        String userId = user.getUserId();
        
        if (isBlank(username) || isBlank(userId)) {
            logger.warn("用户数据缺少关键字段，无法缓存，userId={}, username={}", userId, username);
            return;
        }
        
        String usernameKey = buildUsernameKey(username);
        String idKey = buildIdKey(userId);
        String json = safeSerialize(user);
        
        if (json == null) {
            return;
        }
        
        // 随机 TTL：1800 ~ 2100 秒（30~35分钟）
        int ttl = BASE_CACHE_TTL_SECONDS + new Random().nextInt(TTL_RANDOM_RANGE_SECONDS);
        
        try {
            RedisUtil.pipeline(pipeline -> {
                pipeline.setex(usernameKey, ttl, json);
                pipeline.setex(idKey, ttl, json);
                pipeline.sync();
            });
            recordRedisSuccess();
        } catch (Exception e) {
            recordRedisFailure("cacheUserDoubleKey", e);
        }
    }
    
    /**
     * 缓存空值（短期）
     */
    private void safeCacheEmpty(String cacheKey) {
        try {
            RedisUtil.setex(cacheKey, EMPTY_CACHE_TTL_SECONDS, EMPTY_PLACEHOLDER);
            recordRedisSuccess();
        } catch (Exception e) {
            recordRedisFailure("cacheEmpty", e);
        }
    }
    
    /**
     * 清除用户缓存（静默执行，不抛异常）
     */
    private void evictUserCacheQuietly(String userId, String username) {
        try {
            final String finalUsername;
            final String finalUserId;
            
            if (username != null) {
                finalUsername = username;
            } else if (userId != null) {
                // 尝试从缓存反查 username
                finalUsername = getUsernameByUserIdQuietly(userId);
            } else {
                return;
            }
            
            finalUserId = userId;
            
            RedisUtil.pipeline(pipeline -> {
                if (finalUsername != null) {
                    pipeline.del(buildUsernameKey(finalUsername));
                }
                if (finalUserId != null) {
                    pipeline.del(buildIdKey(finalUserId));
                }
            });
            recordRedisSuccess();
        } catch (Exception e) {
            recordRedisFailure("evictUserCache", e);
        }
    }
    
    /**
     * 延迟删除（简单实现：新开线程）
     * 生产环境建议用定时任务或消息队列
     */
    private void delayedEvict(String userId, String username, long delayMs) {
        new Thread(() -> {
            sleepQuietly(delayMs);
            evictUserCacheQuietly(userId, username);
            logger.debug("延迟删除缓存执行完成，userId={}, username={}", userId, username);
        }).start();
    }
    
    // ==================== 查询辅助方法 ====================
    
    /**
     * 查询数据库并包装结果（带熔断记录）
     */
    private UserQueryResult queryDB(String username, boolean recordFallback) {
        try {
            iUserSTOAdapter user = userDao.findByUsername(username);
            if (user != null) {
                return UserQueryResult.success(user);
            } else {
                return UserQueryResult.notFound();
            }
        } catch (Exception e) {
            logger.error("查询数据库异常，username={}", username, e);
            return UserQueryResult.systemError("数据库查询异常");
        }
    }
    
    /**
     * 通过 username 获取 userId（静默）
     */
    private String getUserIdByUsernameQuietly(String username) {
        if (isBlank(username)) {
            return null;
        }
        
        // 先查缓存
        String cacheKey = buildUsernameKey(username);
        String json = safeRedisGet(cacheKey);
        
        if (json != null && !EMPTY_PLACEHOLDER.equals(json)) {
            iUserSTOAdapter user = safeDeserialize(json);
            if (user != null && !isBlank(user.getUserId())) {
                return user.getUserId();
            }
        }
        
        // 缓存未命中，查数据库
        try {
            iUserSTOAdapter user = userDao.findByUsername(username);
            return user != null ? user.getUserId() : null;
        } catch (Exception e) {
            logger.error("从数据库获取 userId 失败，username={}", username, e);
            return null;
        }
    }
    
    /**
     * 通过 userId 获取 username（静默）
     */
    private String getUsernameByUserIdQuietly(String userId) {
        if (isBlank(userId)) {
            return null;
        }
        
        String cacheKey = buildIdKey(userId);
        String json = safeRedisGet(cacheKey);
        
        if (json != null && !EMPTY_PLACEHOLDER.equals(json)) {
            iUserSTOAdapter user = safeDeserialize(json);
            if (user != null) {
                return user.getUserAccount();
            }
        }
        return null;
    }
    
    // ==================== 熔断器实现 ====================
    
    private boolean isCircuitBreakerOpen() {
        if (!circuitBreakerOpen) {
            return false;
        }
        
        // 检查是否超过熔断时间
        if (System.currentTimeMillis() - circuitBreakerOpenTime > CIRCUIT_BREAKER_TIMEOUT_MS) {
            circuitBreakerOpen = false;
            redisFailureCount.set(0);
            logger.info("Redis 熔断器自动关闭");
            return false;
        }
        
        return true;
    }
    
    private void recordRedisSuccess() {
        // 成功时重置失败计数
        if (redisFailureCount.get() > 0) {
            redisFailureCount.set(0);
        }
    }
    
    private void recordRedisFailure(String operation, Exception e) {
        int failures = redisFailureCount.incrementAndGet();
        logger.error("Redis 操作失败 [{}]，当前连续失败次数：{}", operation, failures, e);
        
        if (failures >= CIRCUIT_BREAKER_THRESHOLD) {
            circuitBreakerOpen = true;
            circuitBreakerOpenTime = System.currentTimeMillis();
            logger.error("Redis 熔断器开启！连续失败 {} 次", failures);
        }
    }
    
    // ==================== 分布式锁（基于 SETNX） ====================
    
    private boolean tryLock(String lockKey) {
        try {
            // SETNX + EXPIRE 保证原子性（假设 RedisUtil 支持）
            Long result = RedisUtil.setnx(lockKey, "1");
            if (result != null && result == 1) {
                RedisUtil.expire(lockKey, LOCK_TTL_SECONDS);
                return true;
            }
            return false;
        } catch (Exception e) {
            recordRedisFailure("tryLock", e);
            return false;
        }
    }
    
    private void releaseLock(String lockKey) {
        try {
            RedisUtil.del(lockKey);
        } catch (Exception e) {
            // 释放锁失败不影响主流程，但需记录
            logger.warn("释放分布式锁失败，lockKey={}", lockKey, e);
        }
    }
    
    // ==================== 异步续期（防雪崩） ====================
    
    private void asyncRefreshIfNeeded(String cacheKey, String cachedJson) {
        // 检查 TTL，如果小于阈值则异步续期
        new Thread(() -> {
            try {
                Long ttl = RedisUtil.ttl(cacheKey);
                if (ttl != null && ttl > 0 && ttl < HALF_TTL_REFRESH_THRESHOLD) {
                    // 续期：重新设置随机 TTL
                    int newTtl = BASE_CACHE_TTL_SECONDS + new Random().nextInt(TTL_RANDOM_RANGE_SECONDS);
                    RedisUtil.expire(cacheKey, newTtl);
                    logger.debug("缓存续期完成，key={}, newTtl={}", cacheKey, newTtl);
                }
            } catch (Exception e) {
                // 续期失败不影响主流程
                logger.debug("缓存续期失败，key={}", cacheKey, e);
            }
        }).start();
    }
    
    // ==================== 安全的 Redis 操作包装 ====================
    
    private String safeRedisGet(String key) {
        try {
            String value = RedisUtil.get(key);
            recordRedisSuccess();
            return value;
        } catch (Exception e) {
            recordRedisFailure("get", e);
            return null;
        }
    }
    
    private void safeRedisDel(String key) {
        try {
            RedisUtil.del(key);
            recordRedisSuccess();
        } catch (Exception e) {
            recordRedisFailure("del", e);
        }
    }
    
    // ==================== 序列化工具（安全版） ====================
    
    private String safeSerialize(iUserSTOAdapter user) {
        if (user == null) {
            return null;
        }
        try {
            return OBJECT_MAPPER.writeValueAsString(user);
        } catch (Exception e) {
            logger.error("序列化用户数据失败", e);
            return null;
        }
    }
    
    private iUserSTOAdapter safeDeserialize(String json) {
        if (isBlank(json)) {
            return null;
        }
        try {
            return OBJECT_MAPPER.readValue(json, iUserSTOAdapter.class);
        } catch (Exception e) {
            logger.error("反序列化用户数据失败，json={}", json, e);
            return null;
        }
    }
    
    // ==================== Key 生成工具 ====================
    
    private String buildUsernameKey(String username) {
        return KEY_PREFIX_USERNAME + username;
    }
    
    private String buildIdKey(String userId) {
        return KEY_PREFIX_ID + userId;
    }
    
    private String buildLockKey(String username) {
        return KEY_PREFIX_LOCK + username;
    }
    
    // ==================== 通用工具方法 ====================
    
    private boolean isBlank(String str) {
        return str == null || str.trim().isEmpty();
    }
    
    private void sleepQuietly(long millis) {
        try {
            Thread.sleep(millis);
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }
    }
    
    // ==================== 业务结果对象（替代异常控制流） ====================
    
    /**
     * 用户查询结果封装
     * 避免用异常控制业务逻辑，明确表达各种结果状态
     */
    public static class UserQueryResult {
        public enum Status {
            SUCCESS,      // 查询成功，用户存在
            NOT_FOUND,    // 查询成功，用户不存在
            PARAM_ERROR,  // 参数错误
            SYSTEM_ERROR  // 系统异常（Redis/DB 故障）
        }
        
        private final Status status;
        private final iUserSTOAdapter user;
        private final String message;
        
        private UserQueryResult(Status status, iUserSTOAdapter user, String message) {
            this.status = status;
            this.user = user;
            this.message = message;
        }
        
        public static UserQueryResult success(iUserSTOAdapter user) {
            return new UserQueryResult(Status.SUCCESS, user, null);
        }
        
        public static UserQueryResult notFound() {
            return new UserQueryResult(Status.NOT_FOUND, null, "用户不存在");
        }
        
        public static UserQueryResult paramError(String message) {
            return new UserQueryResult(Status.PARAM_ERROR, null, message);
        }
        
        public static UserQueryResult systemError(String message) {
            return new UserQueryResult(Status.SYSTEM_ERROR, null, message);
        }
        
        // Getters
        public Status getStatus() { return status; }
        public iUserSTOAdapter getUser() { return user; }
        public String getMessage() { return message; }
        
        public boolean isSuccess() { return status == Status.SUCCESS; }
        public boolean isNotFound() { return status == Status.NOT_FOUND; }
    }

}